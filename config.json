        "comparative": 0.7
      },
      "neutral": {
        "if_else": 1.0,
        "comparative": 0.99,
        "neutral": 0.96,
        "contrastive": 0.9,
        "causal": 0.84,
        "consensus": 0.82,
        "historical": 0.72
      },
      "contradiction": {
        "comparative": 1.0,
        "contrastive": 0.99,
        "causal": 0.97,
        "neutral": 0.89,
        "consensus": 0.84,
        "historical": 0.74,
        "if_else": 0.7
      }
    }
  },
  "difficulty_band_thresholds": {
    "paper_equation": "z_i = easy if m_i >= tau_easy_m and rho_i >= tau_easy_rho; boundary if m_i >= tau_boundary_m and a_i >= tau_boundary_a; hard otherwise",
    "esnli_boundary_mix": {
      "implementation_file": "build_boundary_focus_pack.py",
      "easy": {
        "tau_easy_m": 2.1,
        "tau_easy_rho": null,
        "tau_easy_a": 5
      },
      "boundary": {
        "tau_boundary_m": 1.1,
        "tau_boundary_a": 2
      },
      "hard": "otherwise",
      "retained_bands_for_boundary_mix": [
        "easy",
        "boundary"
      ],
      "label_override_vote_margin": 1.55
    },
    "cqa_boundary_mix": {
      "implementation_file": "build_judge_cqa_outstanding_pack.py",
      "easy": {
        "tau_easy_m": 2.4,
        "tau_easy_rho": null,
        "tau_easy_a": 5
      },
      "boundary": {
        "tau_boundary_m": 1.6,
        "tau_boundary_a": 3
      },
      "hard": "otherwise",
      "retained_bands_for_boundary_mix": [
        "easy",
        "boundary"
      ]
    }
  },
