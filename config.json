  },
  "rationale_quality_score": {
    "paper_equation": "Q(c_i,k) = alpha*S_source + beta*S_ground + gamma*S_cue + delta*S_explicit + eta*S_format + lambda*S_brief + mu*A_i + nu*R_i + rho*M_i",
    "paper_coefficient_names": [
      "alpha",
      "beta",
      "gamma",
      "delta",
      "eta",
      "lambda",
      "mu",
      "nu",
      "rho"
    ],
    "table_2_coefficients": {
      "alpha": 1.0,
      "beta": 0.55,
      "gamma": 0.22,
      "delta": 0.2,
      "eta": 1.0,
      "lambda": 1.0,
      "mu": 0.12,
      "nu": 0.08,
      "rho": 0.03
    },
    "code_component_mapping": {
      "alpha": "source",
      "beta": "ground",
      "gamma": "cue",
      "delta": "explicit",
      "eta": "format",
      "lambda": "brief",
      "mu": "agreement_count",
      "nu": "agreement_ratio",
      "rho": "margin"
    },
    "implementation_file": "build_boundary_focus_pack.py",
    "signal_definitions": {
      "S_source": "pi_D(y_i, s_i,k)",
      "S_ground": "token overlap between rationale and input support tokens",
      "S_cue": "count of label-specific teaching cues found in the rationale",
      "S_explicit": "1.0 if the selected label appears in the rationale, otherwise 0.0",
      "S_format": "0.25 if the rationale contains 'the correct answer' or 'so the answer is', otherwise 0.0",
      "S_brief": "0.25 if 10 <= rationale word count <= 96; -0.15 if word count > 128; otherwise 0.0",
      "A_i": "agreement_count",
      "R_i": "agreement_count / total_candidates",
      "M_i": "vote_margin"
    },
    "signal_values": {
      "format_positive": 0.25,
      "brief_min_words": 10,
      "brief_ideal_word_max": 96,
      "brief_hard_word_max": 128,
      "brief_positive": 0.25,
      "brief_long_penalty": -0.15,
      "cqa_format_weight": 0.08,
      "cqa_cue_weight": 0.08
    }
  },
